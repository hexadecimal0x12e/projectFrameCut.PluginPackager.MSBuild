<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <!--
      Controls whether projectFrameCut generates PluginInfo.sg.cs (partial class) into obj/GeneratedSource
      and adds it to compilation.

      Override in your project:
        <GeneratePluginInfoSource>false</GeneratePluginInfoSource>

      Optional output directory (absolute or relative to project directory):
        <GeneratePluginInfoSourcePath>obj\GeneratedSource</GeneratePluginInfoSourcePath>
    -->
    <GeneratePluginInfoSource Condition="'$(GeneratePluginInfoSource)' == ''">true</GeneratePluginInfoSource>
    <GenerateLoader Condition="'$(GenerateLoader)' == ''">true</GenerateLoader>
    <GeneratePluginInfoSourcePath Condition="'$(GeneratePluginInfoSourcePath)' == ''"></GeneratePluginInfoSourcePath>
  </PropertyGroup>

</Project>
